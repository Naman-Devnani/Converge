# MeetSync Environment Variables
# Copy this file to .env and fill in values as needed.
# No secrets are required for local development — all defaults work out of the box.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the server listens on (default: 3001)
# PORT=3001

# Set to "production" in production environments
# NODE_ENV=development

# Comma-separated list of allowed CORS origins in production.
# Only needed when the frontend and backend are on different domains.
# Leave unset when serving both from the same origin (default Render setup).
# ALLOWED_ORIGIN=https://your-app.onrender.com

# ── Client ────────────────────────────────────────────────────────────────────

# Override the server URL the client connects to.
# Defaults to window.location.origin in production, http://localhost:3001 in dev.
# VITE_SERVER_URL=http://localhost:3001
